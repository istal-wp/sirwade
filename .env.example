# ─────────────────────────────────────────────────────────────
# BRIGHTPATH Loogistics — Environment Variables
# Copy this to .env for local dev (Docker Compose reads it)
# On Railway, set these in the Railway dashboard Variables tab.
# ─────────────────────────────────────────────────────────────

# ── Database (Railway auto-injects MYSQL* when you add MySQL plugin)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=loogistics

# ── Application
APP_ENV=development
APP_SECRET=change-this-to-a-random-string-in-production

# ── Optional overrides (only needed if NOT using Railway MySQL plugin)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASS=
# DB_NAME=loogistics
